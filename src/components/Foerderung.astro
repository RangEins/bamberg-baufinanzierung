---
import { AlertCircle, Landmark, Building, Coins, Sparkles } from '@lucide/astro';
import { FOERDERUNG_ITEMS, FOERDERUNG_HINT, DENKMALSCHUTZ_NOTE } from '@/lib/content';

const iconForTitle = (title: string) => {
  if (title.includes('KfW')) return Building;
  if (title.includes('BAFA')) return Coins;
  if (title.includes('BayernLabo')) return Landmark;
  return Coins;
};
---

<section
  id="foerderung"
  class="relative bg-cream-100 py-16 md:py-24 lg:py-28"
  aria-labelledby="foerderung-heading"
>
  <div class="container-content">
    <div data-reveal class="mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-gold-700">
        Förderlandschaft 2026
      </p>
      <h2
        id="foerderung-heading"
        class="mt-3 font-display text-[1.875rem] leading-tight text-navy-950 sm:text-4xl md:text-5xl"
      >
        Förderungen senken Ihre Rate – wenn die Reihenfolge stimmt.
      </h2>
      <p class="mt-3 text-base text-ink-soft sm:text-lg md:mt-4">
        KfW, BAFA und BayernLabo bieten Programme, die Ihre Finanzierungslast deutlich reduzieren –
        vorausgesetzt, Antrag und Notartermin laufen in der richtigen Reihenfolge.
      </p>
    </div>

    <!-- Three-column grid -->
    <div class="mt-10 grid gap-5 md:mt-14 md:grid-cols-3 md:gap-6 lg:gap-8">
      {FOERDERUNG_ITEMS.map((bucket, idx) => {
        const Icon = iconForTitle(bucket.title);
        return (
          <div
            data-reveal
            data-reveal-delay={idx * 120}
            class="flex flex-col rounded-2xl border border-navy-100 bg-white p-6 shadow-soft transition-all hover:shadow-card md:p-7"
          >
            <div class="flex size-12 items-center justify-center rounded-lg bg-navy-50">
              <Icon class="size-6 text-navy-700" strokeWidth={1.5} />
            </div>
            <h3 class="mt-5 font-display text-xl text-navy-950">
              {bucket.title}
            </h3>
            <ul class="mt-4 space-y-2.5 text-sm text-ink-soft">
              {bucket.items.map((item) => (
                <li class="flex items-start gap-2">
                  <span
                    class="mt-2 size-1.5 shrink-0 rounded-full bg-gold-500"
                    aria-hidden="true"
                  ></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        );
      })}
    </div>

    <!-- Hint-Box -->
    <div
      data-reveal
      data-reveal-delay="200"
      class="mt-8 rounded-xl border border-gold-300/60 bg-gold-50 p-5 md:mt-10 md:p-7"
    >
      <div class="flex items-start gap-4">
        <div class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-gold-100">
          <AlertCircle class="size-5 text-gold-700" strokeWidth={2} />
        </div>
        <div>
          <h3 class="font-display text-lg text-navy-950">Wichtig: Reihenfolge beachten</h3>
          <p class="mt-1.5 text-sm text-ink-soft">{FOERDERUNG_HINT}</p>
        </div>
      </div>
    </div>

    <!-- Denkmalschutz-Block -->
    <div
      data-reveal
      data-reveal-delay="320"
      class="mt-6 overflow-hidden rounded-2xl border border-cream-200 bg-cream-200 md:mt-8"
    >
      <div class="grid gap-0 md:grid-cols-[1fr_2fr]">
        <div class="relative flex flex-col justify-center bg-navy-950 p-6 text-cream-50 sm:p-8 md:p-10">
          <div class="absolute inset-0 opacity-30" aria-hidden="true" style="background: radial-gradient(circle at top right, rgb(201 166 70 / 0.3), transparent 70%);"></div>
          <div class="relative">
            <div class="flex size-10 items-center justify-center rounded-lg bg-gold-500/20">
              <Sparkles class="size-5 text-gold-300" strokeWidth={1.75} />
            </div>
            <h3 class="mt-5 font-display text-2xl">UNESCO-Welterbe</h3>
            <p class="mt-2 text-sm text-cream-100/80">
              Bamberg ist eine der größten unzerstörten Altstädte Deutschlands. Wer hier kauft,
              kauft fast immer denkmalgeschützt.
            </p>
          </div>
        </div>
        <div class="p-6 sm:p-8 md:p-10">
          <p class="text-sm font-semibold uppercase tracking-wider text-gold-700">
            Spezialfall Denkmalschutz
          </p>
          <h3 class="mt-2 font-display text-2xl text-navy-950 md:text-3xl">
            {DENKMALSCHUTZ_NOTE.title}
          </h3>
          <p class="mt-4 text-base leading-relaxed text-ink-soft">
            {DENKMALSCHUTZ_NOTE.body}
          </p>
          <div class="mt-5 grid gap-3 sm:grid-cols-2">
            <div class="rounded-md bg-cream-50 px-4 py-3">
              <div class="text-xs font-semibold uppercase tracking-wider text-gold-700">
                KfW 297/298
              </div>
              <div class="mt-0.5 text-sm text-ink-soft">Klimafreundlicher Neubau & Wohneigentum</div>
            </div>
            <div class="rounded-md bg-cream-50 px-4 py-3">
              <div class="text-xs font-semibold uppercase tracking-wider text-gold-700">
                §7i EStG
              </div>
              <div class="mt-0.5 text-sm text-ink-soft">Erhöhte Denkmal-AfA über 12 Jahre</div>
            </div>
          </div>
          <a
            href="#anfragen"
            class="mt-6 inline-flex h-12 items-center justify-center rounded-md bg-navy-900 px-5 text-sm font-semibold text-cream-50 transition-all hover:bg-navy-800"
          >
            Denkmalschutz-Beratung anfragen
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
