---
import { Phone, Menu } from '@lucide/astro';
import { SITE, NAV_ITEMS } from '@/lib/content';
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-40 transition-all duration-300"
  data-transparent="true"
>
  <div class="container-content flex items-center justify-between gap-6 py-4">
    <a
      href="/"
      class="flex items-baseline gap-2 transition-opacity hover:opacity-80"
      aria-label="Zur Startseite"
    >
      <span class="font-display text-xl font-semibold tracking-tight text-navy-950 site-header-brand">
        {SITE.brand}
      </span>
      <span class="hidden text-sm font-medium text-ink-muted sm:inline site-header-region">
        · Bamberg
      </span>
    </a>

    <nav class="hidden items-center gap-8 lg:flex" aria-label="Hauptnavigation">
      {NAV_ITEMS.map((item) => (
        <a
          href={item.href}
          class="text-sm font-medium text-ink-soft transition-colors hover:text-navy-950 site-header-nav-item"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={`tel:${SITE.phoneTel}`}
        class="hidden items-center gap-2 text-sm font-medium text-ink-soft transition-colors hover:text-navy-950 sm:flex site-header-phone"
        aria-label={`Anrufen ${SITE.phone}`}
      >
        <Phone class="size-4" />
        <span>{SITE.phone}</span>
      </a>
      <a
        href="#anfragen"
        class="inline-flex items-center justify-center rounded-md bg-gold-500 px-4 py-2.5 text-sm font-semibold text-navy-950 shadow-sm transition-all hover:bg-gold-600 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold-300 focus-visible:ring-offset-2"
      >
        Beratung anfragen
      </a>
    </div>
  </div>
</header>

<style>
  #site-header[data-transparent="true"] {
    background-color: transparent;
    backdrop-filter: none;
  }
  #site-header[data-transparent="false"] {
    background-color: rgb(251 248 241 / 0.92);
    backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid rgb(20 32 54 / 0.06);
    box-shadow: 0 1px 0 rgb(20 32 54 / 0.02);
  }
</style>

<script>
  const header = document.getElementById('site-header');
  if (header) {
    const update = () => {
      const scrolled = window.scrollY > 64;
      header.dataset.transparent = String(!scrolled);
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
</script>
