---
import { Phone } from '@lucide/astro';
import { SITE, NAV_ITEMS } from '@/lib/content';
import Logo from '@/components/Logo.astro';
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-40 transition-all duration-300"
  data-transparent="true"
>
  <!--
    Layout-Logik:
    Mobile/Tablet: grid-cols-[auto_1fr_auto] — Logo links, Spacer, Right-Cluster rechts
    Desktop (lg+): grid-cols-3 — drei gleich breite Spalten, Nav in der Mitte
       => Nav sitzt exakt auf der Viewport-Mitte, unabhängig von Logo- und
          Right-Cluster-Breite. Das ist der Grund, warum justify-between mit
          flex-1 nicht ausreicht, wenn die Aussenspalten unterschiedlich breit sind.
  -->
  <div class="container-content grid h-16 items-center gap-4 grid-cols-[auto_1fr_auto] md:h-[76px] md:gap-6 lg:grid-cols-3 lg:gap-8">

    <!-- Spalte 1: Logo -->
    <div class="justify-self-start">
      <div class="logo-dark"><Logo variant="stacked" tone="dark" size="responsive" /></div>
      <div class="logo-light"><Logo variant="stacked" tone="light" size="responsive" /></div>
    </div>

    <!-- Spalte 2: Nav (nur lg+, mittig im Viewport) -->
    <nav
      class="hidden items-center justify-center gap-6 lg:flex lg:justify-self-center xl:gap-9"
      aria-label="Hauptnavigation"
    >
      {NAV_ITEMS.map((item) => (
        <a
          href={item.href}
          class="text-sm font-medium transition-colors nav-link"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Spalte 3: Phone + CTA (rechts) -->
    <div class="flex items-center gap-2 justify-self-end md:gap-3">
      <a
        href={`tel:${SITE.phoneTel}`}
        class="hidden items-center gap-2 text-sm font-medium transition-colors xl:flex phone-link"
        aria-label={`Anrufen ${SITE.phone}`}
      >
        <Phone class="size-4" />
        <span>{SITE.phone}</span>
      </a>

      <a
        href={`tel:${SITE.phoneTel}`}
        class="flex size-11 items-center justify-center rounded-md border transition-colors xl:hidden phone-icon"
        aria-label={`Anrufen ${SITE.phone}`}
      >
        <Phone class="size-[18px]" />
      </a>

      <a
        href="#anfragen"
        class="inline-flex h-11 items-center justify-center whitespace-nowrap rounded-md bg-gold-500 px-4 text-sm font-semibold text-navy-950 shadow-sm transition-all hover:bg-gold-400 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold-300 focus-visible:ring-offset-2 md:h-12 md:px-5"
      >
        <span class="md:hidden">Anfragen</span>
        <span class="hidden md:inline">Beratung anfragen</span>
      </a>
    </div>

  </div>
</header>

<style>
  #site-header[data-transparent="true"] {
    background-color: transparent;
    backdrop-filter: none;
  }
  #site-header[data-transparent="true"] .logo-dark { display: none; }
  #site-header[data-transparent="true"] .logo-light { display: block; }
  #site-header[data-transparent="true"] .nav-link { color: rgb(245 239 226 / 0.85); }
  #site-header[data-transparent="true"] .nav-link:hover { color: rgb(232 199 122); }
  #site-header[data-transparent="true"] .phone-link { color: rgb(245 239 226 / 0.85); }
  #site-header[data-transparent="true"] .phone-link:hover { color: rgb(232 199 122); }
  #site-header[data-transparent="true"] .phone-icon {
    color: rgb(245 239 226 / 0.9);
    border-color: rgb(245 239 226 / 0.25);
  }
  #site-header[data-transparent="true"] .phone-icon:hover {
    color: rgb(232 199 122);
    border-color: rgb(232 199 122 / 0.5);
  }

  #site-header[data-transparent="false"] {
    background-color: rgb(251 248 241 / 0.94);
    backdrop-filter: saturate(180%) blur(14px);
    border-bottom: 1px solid rgb(20 32 54 / 0.08);
    box-shadow: 0 1px 0 rgb(20 32 54 / 0.02);
  }
  #site-header[data-transparent="false"] .logo-dark { display: block; }
  #site-header[data-transparent="false"] .logo-light { display: none; }
  #site-header[data-transparent="false"] .nav-link { color: rgb(44 58 80); }
  #site-header[data-transparent="false"] .nav-link:hover { color: rgb(20 32 54); }
  #site-header[data-transparent="false"] .phone-link { color: rgb(44 58 80); }
  #site-header[data-transparent="false"] .phone-link:hover { color: rgb(20 32 54); }
  #site-header[data-transparent="false"] .phone-icon {
    color: rgb(44 58 80);
    border-color: rgb(20 32 54 / 0.15);
  }
  #site-header[data-transparent="false"] .phone-icon:hover {
    color: rgb(20 32 54);
    border-color: rgb(20 32 54 / 0.3);
  }
</style>

<script>
  const header = document.getElementById('site-header');
  if (header) {
    const update = () => {
      const scrolled = window.scrollY > 32;
      header.dataset.transparent = String(!scrolled);
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
</script>
