---
import { STATS_ITEMS } from '@/lib/content';
---

<section
  aria-label="Kennzahlen"
  class="relative isolate overflow-hidden bg-navy-950 py-10 md:py-14 lg:py-16"
>
  <div
    class="absolute inset-0 -z-10 opacity-30"
    aria-hidden="true"
    style="background: linear-gradient(90deg, transparent, rgb(201 166 70 / 0.15), transparent);"
  >
  </div>

  <div class="container-content">
    <div class="grid grid-cols-2 gap-y-8 sm:gap-y-10 md:grid-cols-4 md:gap-x-8">
      {STATS_ITEMS.map((stat, idx) => (
        <div
          data-reveal
          data-reveal-delay={idx * 80}
          class="group text-center md:text-left"
        >
          <div class="font-display text-3xl font-medium text-gold-400 transition-colors group-hover:text-gold-300 sm:text-4xl md:text-5xl">
            {stat.value}
          </div>
          <div class="mt-1.5 text-[13px] font-medium uppercase tracking-wider text-cream-50 sm:text-sm md:mt-2 md:text-base">
            {stat.label}
          </div>
          <div class="mt-1 text-xs text-cream-100/70 md:text-sm">
            {stat.detail}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
