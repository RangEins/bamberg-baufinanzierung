---
/**
 * Schlanker CI-konformer Cookie-Banner.
 *
 * Aktuell setzt die Seite ausschliesslich technisch notwendige
 * Speicher-Mechanismen ein (keine Tracking-Cookies, kein Analytics,
 * keine externen Fonts). Der Banner informiert kurz und nimmt die
 * Entscheidung des Nutzers im localStorage entgegen.
 *
 * Beim Aktivieren von Analytics zu einem späteren Zeitpunkt kann der
 * Consent-State (window.cookieConsent) abgefragt werden, bevor Skripte
 * geladen werden.
 */
import { ShieldCheck } from '@lucide/astro';
---

<aside
  id="cookie-banner"
  role="dialog"
  aria-live="polite"
  aria-label="Datenschutz-Hinweis"
  aria-hidden="true"
  class="fixed inset-x-3 z-50 mx-auto hidden max-w-3xl rounded-2xl border border-navy-100 bg-cream-50 shadow-2xl shadow-navy-950/20 sm:inset-x-4"
  style="bottom: calc(0.75rem + env(safe-area-inset-bottom, 0px));"
>
  <div class="flex flex-col gap-3 p-4 md:flex-row md:items-center md:gap-6 md:p-6">
    <div class="flex items-start gap-3 md:flex-1">
      <div class="flex size-9 shrink-0 items-center justify-center rounded-lg bg-gold-100">
        <ShieldCheck class="size-5 text-gold-700" strokeWidth={1.75} />
      </div>
      <div class="text-sm leading-relaxed text-ink-soft">
        <p class="font-semibold text-navy-950">
          Cookies &amp; Datenschutz
        </p>
        <p class="mt-1 text-[13px] md:text-sm">
          Wir verwenden technisch notwendige Cookies. Mit Ihrer Einwilligung außerdem
          Statistik- und Marketing-Cookies. Details und Widerruf in der{' '}
          <a
            href="/datenschutz"
            class="font-medium text-navy-900 underline underline-offset-2 hover:text-gold-700"
          >
            Datenschutzerklärung
          </a>.
        </p>
      </div>
    </div>

    <div class="grid shrink-0 grid-cols-2 gap-2 md:flex md:items-center md:gap-3">
      <button
        type="button"
        data-cookie-action="essential"
        class="inline-flex h-11 items-center justify-center rounded-md border border-navy-200 px-4 text-sm font-medium text-navy-900 transition-colors hover:bg-navy-50"
      >
        Nur notwendig
      </button>
      <button
        type="button"
        data-cookie-action="accept"
        class="inline-flex h-11 items-center justify-center rounded-md bg-gold-500 px-4 text-sm font-semibold text-navy-950 shadow-sm transition-all hover:bg-gold-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold-300 focus-visible:ring-offset-2"
      >
        Alle akzeptieren
      </button>
    </div>
  </div>
</aside>

<script>
  const STORAGE_KEY = 'bb-cookie-consent';
  const banner = document.getElementById('cookie-banner');

  function showBanner() {
    if (!banner) return;
    banner.classList.remove('hidden');
    banner.setAttribute('aria-hidden', 'false');
    // Mini-Slide-up
    requestAnimationFrame(() => {
      banner.animate(
        [
          { transform: 'translateY(24px)', opacity: 0 },
          { transform: 'translateY(0)', opacity: 1 },
        ],
        { duration: 320, easing: 'cubic-bezier(0.16, 1, 0.3, 1)', fill: 'forwards' },
      );
    });
  }

  function hideBanner() {
    if (!banner) return;
    const anim = banner.animate(
      [
        { transform: 'translateY(0)', opacity: 1 },
        { transform: 'translateY(24px)', opacity: 0 },
      ],
      { duration: 240, easing: 'cubic-bezier(0.7, 0, 0.84, 0)', fill: 'forwards' },
    );
    anim.onfinish = () => {
      banner.classList.add('hidden');
      banner.setAttribute('aria-hidden', 'true');
    };
  }

  function saveChoice(value: 'essential' | 'all') {
    try {
      window.localStorage.setItem(
        STORAGE_KEY,
        JSON.stringify({ value, ts: Date.now() }),
      );
    } catch {
      // localStorage nicht verfügbar — ignorieren
    }
    (window as any).cookieConsent = value;
    document.dispatchEvent(new CustomEvent('cookieconsent', { detail: { value } }));
  }

  function init() {
    if (!banner) return;
    let saved: string | null = null;
    try {
      saved = window.localStorage.getItem(STORAGE_KEY);
    } catch {
      // ignore
    }
    if (saved) {
      try {
        const parsed = JSON.parse(saved);
        (window as any).cookieConsent = parsed?.value || 'essential';
      } catch {
        (window as any).cookieConsent = 'essential';
      }
      return;
    }
    showBanner();
  }

  banner?.querySelectorAll<HTMLButtonElement>('[data-cookie-action]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const action = btn.dataset.cookieAction === 'accept' ? 'all' : 'essential';
      saveChoice(action);
      hideBanner();
    });
  });

  // Zeige Banner sobald DOM bereit ist
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
