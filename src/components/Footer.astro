---
import { Phone, Mail, MapPin, Smartphone } from '@lucide/astro';
import { SITE, FOOTER_LINKS } from '@/lib/content';
import Logo from '@/components/Logo.astro';
import BlurOrb from '@/components/util/BlurOrb.astro';

const year = new Date().getFullYear();
---

<footer class="relative isolate overflow-hidden bg-navy-950 text-cream-100/90">
  <BlurOrb color="gold" size="lg" position="top-right" opacity={0.15} />

  <div class="container-content relative py-12 md:py-16 lg:py-20">
    <div class="grid gap-8 md:grid-cols-2 md:gap-10 lg:grid-cols-4 lg:gap-12">
      <!-- Brand + NAP -->
      <div class="lg:col-span-1">
        <Logo variant="stacked" tone="light" size="lg" withLink={false} />
        <p class="mt-5 text-sm leading-relaxed text-cream-100/80">
          Unabhängige Baufinanzierung für Bamberg, den Landkreis Bamberg und Oberfranken.
          Über 600 Banken im Vergleich, 15 Jahre Markterfahrung.
        </p>

        <!-- Berater-Karte: Profilbild + Name als Trust-Signal über den Kontaktdaten -->
        <div class="mt-7 flex items-center gap-4 rounded-xl border border-cream-50/10 bg-white/[0.03] p-3.5">
          <img
            src="/profilbild.webp"
            alt="Christoph Altemeier"
            width="56"
            height="56"
            loading="lazy"
            decoding="async"
            class="size-14 shrink-0 rounded-full object-cover ring-2 ring-gold-500/40"
          />
          <div class="min-w-0">
            <div class="text-[10px] font-semibold uppercase tracking-[0.18em] text-gold-400">
              Ihr Ansprechpartner
            </div>
            <div class="mt-0.5 font-display text-base text-cream-50">
              Christoph Altemeier
            </div>
          </div>
        </div>

        <ul class="mt-5 space-y-3 text-sm">
          <li>
            <a
              href={`tel:${SITE.phoneTel}`}
              class="inline-flex items-center gap-2.5 text-cream-50 transition-colors hover:text-gold-300"
            >
              <Phone class="size-4 text-gold-400" />
              {SITE.phone}
            </a>
          </li>
          <li>
            <a
              href={`tel:${SITE.mobileTel}`}
              class="inline-flex items-center gap-2.5 text-cream-50 transition-colors hover:text-gold-300"
            >
              <Smartphone class="size-4 text-gold-400" />
              {SITE.mobile}
            </a>
          </li>
          <li>
            <a
              href={`mailto:${SITE.email}`}
              class="inline-flex items-center gap-2.5 text-cream-50 transition-colors hover:text-gold-300"
            >
              <Mail class="size-4 text-gold-400" />
              {SITE.email}
            </a>
          </li>
          <li class="inline-flex items-center gap-2.5 text-cream-100/80">
            <MapPin class="size-4 text-gold-400" />
            Bamberg, Bayern
          </li>
        </ul>
      </div>

      <!-- Leistungen -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gold-400">
          Leistungen
        </h3>
        <ul class="mt-5 space-y-2.5 text-sm">
          {FOOTER_LINKS.leistungen.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-cream-100/80 transition-colors hover:text-cream-50"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Regionen -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gold-400">
          Regionen
        </h3>
        <ul class="mt-5 space-y-2.5 text-sm">
          {FOOTER_LINKS.regionen.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-cream-100/80 transition-colors hover:text-cream-50"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Informationen -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gold-400">
          Informationen
        </h3>
        <ul class="mt-5 space-y-2.5 text-sm">
          {FOOTER_LINKS.informationen.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-cream-100/80 transition-colors hover:text-cream-50"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom row -->
    <div class="mt-10 flex flex-col items-start justify-between gap-3 border-t border-cream-50/10 pt-6 text-xs text-cream-100/70 md:mt-12 md:flex-row md:items-center">
      <div>
        © {year} {SITE.brand} · Alle Rechte vorbehalten
      </div>
      <div class="flex items-center gap-4">
        <a href="/impressum" class="hover:text-cream-50">Impressum</a>
        <a href="/datenschutz" class="hover:text-cream-50">Datenschutz</a>
      </div>
    </div>
  </div>
</footer>
