---
import { Phone, Mail, MapPin, ExternalLink } from '@lucide/astro';
import { SITE, FOOTER_LINKS, SISTER_SITES } from '@/lib/content';
import BlurOrb from '@/components/util/BlurOrb.astro';

const year = new Date().getFullYear();
---

<footer class="relative isolate overflow-hidden bg-navy-950 text-cream-100/85">
  <BlurOrb color="gold" size="lg" position="top-right" opacity={0.15} />

  <div class="container-content relative py-16 md:py-20">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4 lg:gap-12">
      <!-- Brand + NAP -->
      <div class="lg:col-span-1">
        <div class="font-display text-2xl text-cream-50">
          {SITE.brand}
        </div>
        <p class="mt-1 text-sm text-gold-400">Standort Bamberg</p>
        <p class="mt-4 text-sm leading-relaxed text-cream-100/70">
          Unabhängige Baufinanzierung für Bamberg, den Landkreis Bamberg und Oberfranken.
          Persönlich begleitet durch {SITE.advisor}.
        </p>

        <ul class="mt-6 space-y-3 text-sm">
          <li>
            <a
              href={`tel:${SITE.phoneTel}`}
              class="inline-flex items-center gap-2.5 transition-colors hover:text-gold-300"
            >
              <Phone class="size-4 text-gold-400" />
              {SITE.phone}
            </a>
          </li>
          <li>
            <a
              href={`mailto:${SITE.email}`}
              class="inline-flex items-center gap-2.5 transition-colors hover:text-gold-300"
            >
              <Mail class="size-4 text-gold-400" />
              {SITE.email}
            </a>
          </li>
          <li class="inline-flex items-center gap-2.5 text-cream-100/70">
            <MapPin class="size-4 text-gold-400" />
            Bamberg, Bayern
          </li>
        </ul>
      </div>

      <!-- Leistungen -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gold-400">
          Leistungen
        </h3>
        <ul class="mt-5 space-y-2.5 text-sm">
          {FOOTER_LINKS.leistungen.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-cream-100/70 transition-colors hover:text-cream-50"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Regionen -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gold-400">
          Regionen
        </h3>
        <ul class="mt-5 space-y-2.5 text-sm">
          {FOOTER_LINKS.regionen.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-cream-100/70 transition-colors hover:text-cream-50"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Informationen -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gold-400">
          Informationen
        </h3>
        <ul class="mt-5 space-y-2.5 text-sm">
          {FOOTER_LINKS.informationen.map((link) => (
            <li>
              <a
                href={link.href}
                target={'external' in link && link.external ? '_blank' : undefined}
                rel={'external' in link && link.external ? 'noopener noreferrer' : undefined}
                class="inline-flex items-center gap-1 text-cream-100/70 transition-colors hover:text-cream-50"
              >
                {link.label}
                {'external' in link && link.external && (
                  <ExternalLink class="size-3" />
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Sister sites -->
    <div class="mt-14 border-t border-cream-50/10 pt-10">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-gold-400">
        Auch in Ihrer Region beraten
      </h3>
      <div class="mt-5 flex flex-wrap gap-x-6 gap-y-3 text-sm">
        {SISTER_SITES.map((site) => (
          <a
            href={site.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 text-cream-100/70 transition-colors hover:text-gold-300"
          >
            {site.name}
            <ExternalLink class="size-3" />
          </a>
        ))}
      </div>
    </div>

    <!-- Bottom row -->
    <div class="mt-12 flex flex-col items-start justify-between gap-3 border-t border-cream-50/10 pt-6 text-xs text-cream-100/50 md:flex-row md:items-center">
      <div>
        © {year} {SITE.brand} · Alle Rechte vorbehalten
      </div>
      <div class="flex items-center gap-4">
        <a href="/impressum" class="hover:text-cream-50">Impressum</a>
        <a href="/datenschutz" class="hover:text-cream-50">Datenschutz</a>
      </div>
    </div>
  </div>
</footer>
