---
import { Phone, ShieldCheck, Award, Clock3 } from '@lucide/astro';
import { SITE, HERO } from '@/lib/content';
import { LeadWizard } from '@/components/wizard/LeadWizard';
import BlurOrb from '@/components/util/BlurOrb.astro';
---

<section
  id="hero"
  class="relative isolate overflow-hidden bg-navy-950 pt-28 pb-20 md:pt-36 md:pb-24 lg:pt-44 lg:pb-32"
>
  <!-- Decorative background -->
  <div
    class="absolute inset-0 -z-10"
    aria-hidden="true"
    style="background: linear-gradient(180deg, #0A1424 0%, #142036 60%, #1E3050 100%);"
  >
  </div>

  <BlurOrb color="gold" size="xl" position="top-right" opacity={0.18} />
  <BlurOrb color="navy" size="lg" position="bottom-left" opacity={0.3} />

  <!-- Subtle topographic overlay (SVG pattern) -->
  <div
    class="absolute inset-0 -z-10 opacity-[0.04]"
    aria-hidden="true"
    style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 24px 24px;"
  >
  </div>

  <div class="container-content">
    <div class="grid items-start gap-12 lg:grid-cols-[1.1fr_1fr] lg:gap-16">
      <!-- Left column: copy -->
      <div class="text-cream-50">
        <div data-reveal class="inline-flex items-center gap-2 rounded-full border border-gold-500/30 bg-gold-500/10 px-4 py-1.5 text-xs font-medium uppercase tracking-wider text-gold-300">
          <span class="size-1.5 rounded-full bg-gold-400"></span>
          {HERO.badge}
        </div>

        <h1
          data-reveal
          data-reveal-delay="120"
          class="mt-6 font-display text-4xl font-medium leading-[1.05] tracking-tight sm:text-5xl md:text-6xl lg:text-[4rem]"
        >
          <span class="text-cream-50">{HERO.headline}</span>
          <span class="mt-2 block text-gold-400">{HERO.headlineAccent}</span>
        </h1>

        <p
          data-reveal
          data-reveal-delay="240"
          class="mt-6 max-w-xl text-lg leading-relaxed text-cream-100/85 md:text-xl"
        >
          {HERO.subtitle}
        </p>

        <ul
          data-reveal
          data-reveal-delay="360"
          class="mt-8 flex flex-wrap gap-x-6 gap-y-3 text-sm text-cream-100/80"
        >
          <li class="flex items-center gap-2">
            <Award class="size-4 text-gold-400" />
            {HERO.trustBadges[0]}
          </li>
          <li class="flex items-center gap-2">
            <ShieldCheck class="size-4 text-gold-400" />
            {HERO.trustBadges[1]}
          </li>
          <li class="flex items-center gap-2">
            <Clock3 class="size-4 text-gold-400" />
            {HERO.trustBadges[2]}
          </li>
        </ul>

        <div
          data-reveal
          data-reveal-delay="480"
          class="mt-10 flex flex-col gap-3 sm:flex-row sm:items-center"
        >
          <a
            href="#anfragen"
            class="inline-flex items-center justify-center rounded-md bg-gold-500 px-6 py-3.5 text-base font-semibold text-navy-950 shadow-lg shadow-gold-500/20 transition-all hover:bg-gold-400 hover:shadow-xl hover:shadow-gold-500/30 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold-300 focus-visible:ring-offset-2 focus-visible:ring-offset-navy-950"
          >
            {HERO.cta}
          </a>
          <a
            href={`tel:${SITE.phoneTel}`}
            class="inline-flex items-center justify-center gap-2 rounded-md border border-cream-50/20 bg-white/5 px-6 py-3.5 text-base font-medium text-cream-50 backdrop-blur-sm transition-all hover:border-cream-50/40 hover:bg-white/10"
          >
            <Phone class="size-4" />
            {SITE.phone}
          </a>
        </div>

        <p
          data-reveal
          data-reveal-delay="600"
          class="mt-8 text-sm text-cream-100/60"
        >
          Persönliche Beratung durch <span class="text-cream-100">{SITE.advisor}</span> · 25 Jahre Markterfahrung in Franken · Mutterseite {SITE.parent}
        </p>
      </div>

      <!-- Right column: Wizard -->
      <div
        data-reveal
        data-reveal-delay="320"
        class="relative lg:sticky lg:top-28"
        id="anfragen"
      >
        <div
          class="absolute -inset-4 -z-10 rounded-3xl bg-gold-500/10 blur-2xl"
          aria-hidden="true"
        >
        </div>
        <LeadWizard client:visible />
      </div>
    </div>
  </div>

  <!-- Decorative bottom fade into cream-50 -->
  <div
    class="absolute inset-x-0 bottom-0 h-24"
    aria-hidden="true"
    style="background: linear-gradient(to bottom, transparent, var(--color-cream-50));"
  >
  </div>
</section>
