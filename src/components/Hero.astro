---
import { Phone, ShieldCheck, Award, Clock3 } from '@lucide/astro';
import { SITE, HERO } from '@/lib/content';
import { LeadWizard } from '@/components/wizard/LeadWizard';
import BlurOrb from '@/components/util/BlurOrb.astro';
---

<section
  id="hero"
  class="relative isolate overflow-hidden bg-navy-950 pb-14 pt-[calc(6rem+env(safe-area-inset-top,0px))] md:pb-16 md:pt-[calc(7rem+env(safe-area-inset-top,0px))] lg:pb-20"
>
  <div
    class="absolute inset-0 -z-10"
    aria-hidden="true"
    style="background: linear-gradient(180deg, #0A1424 0%, #142036 60%, #1E3050 100%);"
  >
  </div>

  <BlurOrb color="gold" size="xl" position="top-right" opacity={0.18} />
  <BlurOrb color="navy" size="lg" position="bottom-left" opacity={0.3} />

  <div
    class="absolute inset-0 -z-10 opacity-[0.04]"
    aria-hidden="true"
    style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 24px 24px;"
  >
  </div>

  <div class="container-content">
    <div class="grid items-start gap-10 lg:grid-cols-[1.05fr_1fr] lg:gap-12">
      <!-- Left column: copy -->
      <div class="text-cream-50">
        <div
          data-reveal
          class="inline-flex items-center gap-2 rounded-full border border-gold-500/30 bg-gold-500/10 px-3.5 py-1.5 text-[11px] font-medium uppercase tracking-wider text-gold-300 md:text-xs"
        >
          <span class="size-1.5 rounded-full bg-gold-400"></span>
          <span class="md:hidden">Unabhängig · Bamberg & Landkreis</span>
          <span class="hidden md:inline">{HERO.badge}</span>
        </div>

        <h1
          data-reveal
          data-reveal-delay="120"
          class="mt-4 font-display text-[2rem] font-medium leading-[1.05] tracking-tight sm:text-[2.75rem] md:mt-5 md:text-[3rem] lg:text-[3.25rem] xl:text-[3.5rem]"
        >
          <span class="text-cream-50">{HERO.headline}</span>
          <span class="mt-1 block text-gold-400 md:mt-1.5">{HERO.headlineAccent}</span>
        </h1>

        <p
          data-reveal
          data-reveal-delay="240"
          class="mt-4 max-w-xl text-[15px] leading-relaxed text-cream-100/85 sm:text-base md:mt-5 md:text-lg"
        >
          {HERO.subtitle}
        </p>

        <div
          data-reveal
          data-reveal-delay="360"
          class="mt-6 flex flex-col gap-2.5 sm:flex-row sm:items-center md:mt-7 md:gap-3"
        >
          <a
            href="#anfragen"
            class="inline-flex h-12 items-center justify-center rounded-md bg-gold-500 px-6 text-base font-semibold text-navy-950 shadow-lg shadow-gold-500/20 transition-all hover:bg-gold-400 hover:shadow-xl hover:shadow-gold-500/30 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold-300 focus-visible:ring-offset-2 focus-visible:ring-offset-navy-950 md:h-[52px]"
          >
            {HERO.cta}
          </a>
          <a
            href={`tel:${SITE.phoneTel}`}
            class="inline-flex h-12 items-center justify-center gap-2 rounded-md border border-cream-50/20 bg-white/5 px-5 text-base font-medium text-cream-50 backdrop-blur-sm transition-all hover:border-cream-50/40 hover:bg-white/10 md:h-[52px]"
          >
            <Phone class="size-4" />
            <span>{SITE.phone}</span>
          </a>
        </div>

        <ul
          data-reveal
          data-reveal-delay="480"
          class="mt-5 flex flex-wrap gap-x-5 gap-y-2.5 text-[13px] text-cream-100/80 md:mt-6 md:gap-x-6 md:gap-y-3 md:text-sm"
        >
          <li class="flex items-center gap-1.5 md:gap-2">
            <Award class="size-3.5 text-gold-400 md:size-4" />
            {HERO.trustBadges[0]}
          </li>
          <li class="flex items-center gap-1.5 md:gap-2">
            <ShieldCheck class="size-3.5 text-gold-400 md:size-4" />
            {HERO.trustBadges[1]}
          </li>
          <li class="flex items-center gap-1.5 md:gap-2">
            <Clock3 class="size-3.5 text-gold-400 md:size-4" />
            {HERO.trustBadges[2]}
          </li>
        </ul>
      </div>

      <!-- Right column: Wizard — rückt mit Negative-Margin hoch (Desktop), startet näher am Header -->
      <div
        data-reveal
        data-reveal-delay="320"
        class="relative lg:-mt-6 lg:sticky lg:top-24"
        id="anfragen"
      >
        <!-- Gold-Glow hinter dem Wizard nur ab md sichtbar (blur-2xl ist auf Mobile-GPU teuer) -->
        <div
          class="absolute -inset-4 -z-10 hidden rounded-3xl bg-gold-500/10 md:block md:blur-2xl"
          aria-hidden="true"
        >
        </div>
        <LeadWizard client:visible />
      </div>
    </div>
  </div>

  <div
    class="absolute inset-x-0 bottom-0 h-20 md:h-24"
    aria-hidden="true"
    style="background: linear-gradient(to bottom, transparent, var(--color-cream-50));"
  >
  </div>
</section>
