---
/**
 * Eigenständige Wortmarke "Baufinanzierung Bamberg".
 *
 * Editorial-orientierter Wordmark mit vertikaler Goldlinie als
 * Struktur-Element (Masthead-Stil aus dem Verlagswesen).
 * Keine Icon-Spielerei – die Fraunces-Serife trägt die Markenidentität.
 *
 * variants:
 *   stacked  – zwei Zeilen, default für Header und Footer
 *   inline   – einzeilig, für sehr kompakte Stellen
 */

interface Props {
  variant?: 'stacked' | 'inline';
  tone?: 'dark' | 'light';
  size?: 'sm' | 'md' | 'lg' | 'responsive';
  withLink?: boolean;
  class?: string;
}

const {
  variant = 'stacked',
  tone = 'dark',
  size = 'md',
  withLink = true,
  class: className = '',
} = Astro.props;

const isResponsive = size === 'responsive';

const barClass = isResponsive
  ? 'h-9 w-[3px] md:h-11 md:w-[3px]'
  : { sm: 'h-8 w-[2.5px]', md: 'h-10 w-[3px]', lg: 'h-12 w-[3px]' }[
      size as 'sm' | 'md' | 'lg'
    ];

const eyebrowClass = isResponsive
  ? 'text-[10px] tracking-[0.18em] md:text-[11px] md:tracking-[0.22em]'
  : {
      sm: 'text-[10px] tracking-[0.18em]',
      md: 'text-[11px] tracking-[0.22em]',
      lg: 'text-xs tracking-[0.22em]',
    }[size as 'sm' | 'md' | 'lg'];

const wordmarkClass = isResponsive
  ? 'text-[17px] md:text-[22px]'
  : { sm: 'text-base', md: 'text-[22px]', lg: 'text-[26px]' }[size as 'sm' | 'md' | 'lg'];

const gapClass = isResponsive ? 'gap-2.5 md:gap-3' : 'gap-3';

const eyebrowColor = tone === 'dark' ? 'text-ink-muted' : 'text-cream-100/70';
const wordmarkColor = tone === 'dark' ? 'text-navy-950' : 'text-cream-50';

const Wrapper = withLink ? 'a' : 'div';
---

<Wrapper
  {...withLink ? { href: '/', 'aria-label': 'Baufinanzierung Bamberg – zur Startseite' } : {}}
  class={`group inline-flex items-center ${gapClass} ${withLink ? 'transition-opacity hover:opacity-90' : ''} ${className}`}
>
  <!-- Vertikaler Gold-Stick als Masthead-Element -->
  <div
    aria-hidden="true"
    class={`shrink-0 rounded-full bg-gold-500 ${barClass}`}
  >
  </div>

  {variant === 'stacked' && (
    <div class="leading-none">
      <div class={`font-body font-medium uppercase ${eyebrowClass} ${eyebrowColor}`}>
        Baufinanzierung
      </div>
      <div class={`mt-1 md:mt-1.5 font-display ${wordmarkClass} font-medium tracking-tight ${wordmarkColor}`}>
        Bamberg
      </div>
    </div>
  )}

  {variant === 'inline' && (
    <span class={`font-display ${wordmarkClass} font-medium tracking-tight ${wordmarkColor}`}>
      Baufinanzierung&nbsp;Bamberg
    </span>
  )}
</Wrapper>
