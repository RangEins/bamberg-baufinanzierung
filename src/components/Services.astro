---
import { Home, Repeat, Wrench, Coins, ArrowUpRight } from '@lucide/astro';
import { SERVICES } from '@/lib/content';

const iconMap = { Home, Repeat, Wrench, Coins };
---

<section
  id="leistungen"
  class="bg-cream-50 py-16 md:py-24 lg:py-28"
  aria-labelledby="leistungen-heading"
>
  <div class="container-content">
    <div data-reveal class="mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-gold-700">
        Unsere Leistungen
      </p>
      <h2
        id="leistungen-heading"
        class="mt-3 font-display text-[1.875rem] leading-tight text-navy-950 sm:text-4xl md:text-5xl"
      >
        Vier Bereiche, in denen wir Sie konkret unterstützen.
      </h2>
      <p class="mt-3 text-base text-ink-soft sm:text-lg md:mt-4">
        Von der Erstfinanzierung über die Anschluss-Sicherung bis zur Förderprüfung – wir
        begleiten alle Phasen Ihrer Immobilienreise in Bamberg.
      </p>
    </div>

    <div class="mt-10 grid gap-5 md:mt-14 md:grid-cols-2 md:gap-6 lg:mt-16 lg:gap-8">
      {SERVICES.map((service, idx) => {
        const Icon = iconMap[service.icon as keyof typeof iconMap];
        return (
          <a
            data-reveal
            data-reveal-delay={idx * 100}
            href={service.anchor}
            class="group relative flex flex-col overflow-hidden rounded-2xl border border-navy-100 bg-white p-6 shadow-soft transition-all hover:-translate-y-1 hover:border-gold-300 hover:shadow-card md:p-7 lg:p-8"
          >
            <div
              class="absolute inset-x-0 top-0 h-1 origin-left scale-x-0 bg-gold-500 transition-transform duration-500 group-hover:scale-x-100"
              aria-hidden="true"
            >
            </div>

            <div class="flex size-14 items-center justify-center rounded-xl bg-navy-50 transition-colors group-hover:bg-gold-100">
              <Icon class="size-7 text-navy-700 transition-colors group-hover:text-gold-700" strokeWidth={1.5} />
            </div>

            <h3 class="mt-5 font-display text-xl text-navy-950 md:text-2xl">
              {service.title}
            </h3>
            <p class="mt-3 flex-1 text-base text-ink-soft">
              {service.description}
            </p>

            <span class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-navy-900 transition-colors group-hover:text-gold-700">
              Mehr erfahren
              <ArrowUpRight class="size-4 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
            </span>
          </a>
        );
      })}
    </div>
  </div>
</section>
