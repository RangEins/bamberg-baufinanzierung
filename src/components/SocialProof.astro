---
import { Star } from '@lucide/astro';

/**
 * Sterne-Bewertung als kompaktes Social-Proof-Element.
 *
 * Bewusst KEIN Link auf das GMB-Profil und KEIN AggregateRating-JSON-LD —
 * die Bewertung wird nur visuell dargestellt. (Das GMB-Profil ist mit der
 * Hauptmarke verknüpft, nicht mit diesem Standort-Mikrosite.)
 *
 * Partial-Fill der Sterne über überlagerte Layer + overflow-hidden Clipping.
 */

interface Props {
  rating?: number;
  total?: number;
  tone?: 'dark' | 'light';
  size?: 'sm' | 'md';
  class?: string;
}

const {
  rating = 5,
  total = 36,
  tone = 'light',
  size = 'md',
  class: className = '',
} = Astro.props;

const ratingFormatted = rating.toFixed(1).replace('.', ',');
const fillPercentage = Math.min(100, Math.max(0, (rating / 5) * 100));

const starSize = size === 'sm' ? 16 : 18;
const starGap = 2;
const totalWidth = 5 * starSize + 4 * starGap;

const fullClass =
  tone === 'dark' ? 'fill-gold-500 text-gold-500' : 'fill-gold-400 text-gold-400';
const emptyClass = tone === 'dark' ? 'text-navy-200' : 'text-cream-50/25';

const numberColor = tone === 'dark' ? 'text-navy-950' : 'text-cream-50';
const labelColor = tone === 'dark' ? 'text-ink-muted' : 'text-cream-100/75';

const textSize = size === 'sm' ? 'text-[13px]' : 'text-sm';
---

<div
  class={`inline-flex items-center gap-2.5 ${className}`}
  role="img"
  aria-label={`${ratingFormatted} von 5 Sternen bei ${total} Google-Bewertungen`}
>
  <div
    class="relative inline-flex shrink-0"
    style={`width: ${totalWidth}px; height: ${starSize}px;`}
  >
    <!-- Empty-Layer (Background) -->
    <div class="flex items-center" style={`gap: ${starGap}px;`}>
      {Array.from({ length: 5 }).map(() => (
        <Star
          class={`shrink-0 ${emptyClass}`}
          size={starSize}
          strokeWidth={1.5}
        />
      ))}
    </div>
    <!-- Filled-Layer (Foreground, clipped via overflow-hidden) -->
    <div
      class="absolute inset-y-0 left-0 overflow-hidden"
      style={`width: ${fillPercentage}%;`}
      aria-hidden="true"
    >
      <div class="flex items-center" style={`gap: ${starGap}px;`}>
        {Array.from({ length: 5 }).map(() => (
          <Star
            class={`shrink-0 ${fullClass}`}
            size={starSize}
            strokeWidth={1.5}
          />
        ))}
      </div>
    </div>
  </div>
  <div class={textSize}>
    <span class={`font-semibold ${numberColor}`}>{ratingFormatted}</span>
    <span class={labelColor}> von 5 · {total} Google-Bewertungen</span>
  </div>
</div>
